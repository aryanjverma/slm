__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Keep data/eval artifacts, but avoid accidentally committing large checkpoints.
artifacts/models/

# College Board / Tom Richey PDF binaries — use catalog scripts to download locally.
artifacts/raw/ap_central/*.pdf
artifacts/raw/tomrichey/*.pdf

# Auto-generated eval table written by the notebook at runtime; the curated copy
# lives at docs/v1_eval_results.md. Ignored so it never blocks `git pull`.
artifacts/eval/v1_eval_results.md

# Written permission records may contain private correspondence or identifiers.
config/college_board_permission.json

# V5 runtime logs only — essays/labels/packets may be committed in a private repo.
artifacts/data/v5/private/logs/
